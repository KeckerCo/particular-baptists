---
import { NAV_LINKS, SITE_SHORT_TITLE, SITE_TITLE } from '../consts';
---

<header>
<nav class="nav-shell">
<a class="brand-lockup" href="/" aria-label={SITE_TITLE}>
<img src="/irbs-wordmark.svg" alt="IRBS" class="brand-wordmark" width="90" height="28" />
<span class="brand-divider" aria-hidden="true">|</span>
<span class="brand-title">{SITE_SHORT_TITLE}</span>
</a>

<button class="nav-toggle" id="navToggle" aria-label="Open navigation" aria-expanded="false">
<svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
<rect y="3" width="18" height="1.5" rx="0.75" fill="currentColor"/>
<rect y="8" width="18" height="1.5" rx="0.75" fill="currentColor"/>
<rect y="13" width="18" height="1.5" rx="0.75" fill="currentColor"/>
</svg>
</button>

<div class="internal-links" id="navLinks">
{NAV_LINKS.map((link) => (
<a href={link.href} class={Astro.url.pathname === link.href ? 'active' : undefined}>
{link.label}
</a>
))}
</div>
</nav>
</header>

<script>
const toggle = document.getElementById('navToggle');
const links = document.getElementById('navLinks');
toggle?.addEventListener('click', () => {
const expanded = toggle.getAttribute('aria-expanded') === 'true';
toggle.setAttribute('aria-expanded', String(!expanded));
links?.classList.toggle('open');
});
</script>

<style>
header {
position: sticky;
top: 0;
z-index: 50;
background: rgba(250, 249, 247, 0.95);
backdrop-filter: blur(12px);
border-bottom: 1px solid #e0dbd5;
}

.nav-shell {
display: flex;
align-items: center;
justify-content: space-between;
gap: 1rem;
max-width: 70rem;
margin: 0 auto;
padding: 0 1.5rem;
height: 3.5rem;
}

.brand-lockup {
display: flex;
align-items: center;
gap: 0.75rem;
text-decoration: none;
flex-shrink: 0;
}

.brand-wordmark {
display: block;
height: 28px;
width: auto;
}

.brand-divider {
font-family: 'Inter', system-ui, sans-serif;
font-size: 0.8rem;
color: #ccc;
line-height: 1;
}

.brand-title {
font-family: 'EB Garamond', Georgia, serif;
font-size: 1.05rem;
font-weight: 500;
color: #111;
line-height: 1;
}

.internal-links {
display: flex;
align-items: center;
gap: 1.5rem;
}

.internal-links a {
font-family: 'Inter', system-ui, sans-serif;
font-size: 0.8125rem;
font-weight: 500;
color: #666;
text-decoration: none;
transition: color 0.12s;
}

.internal-links a:hover,
.internal-links a.active {
color: #111;
}

.internal-links a.active {
color: #971b2f;
}

.nav-toggle {
display: none;
padding: 0.375rem;
border: none;
background: transparent;
color: #666;
cursor: pointer;
}

@media (max-width: 42rem) {
.nav-shell { padding: 0 1rem; }

.nav-toggle { display: flex; align-items: center; }

.internal-links {
display: none;
position: absolute;
top: 3.5rem;
left: 0;
right: 0;
flex-direction: column;
align-items: stretch;
background: #faf9f7;
border-bottom: 1px solid #e0dbd5;
padding: 0.5rem 1rem 1rem;
gap: 0;
}

.internal-links.open { display: flex; }

.internal-links a {
padding: 0.75rem 0;
font-size: 0.9375rem;
border-bottom: 1px solid #e0dbd5;
}

.internal-links a:last-child { border-bottom: none; }
}
</style>
