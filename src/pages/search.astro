---
import { authors } from '../data/catalog';
import SiteShell from '../layouts/SiteShell.astro';
export const prerender = true;

const description = 'Search the writings of the Particular Baptists by title, author, or passage.';
---

<SiteShell title="Search" description={description}>
	<section class="page-intro">
		<div>
			<p class="eyebrow">Search the library</p>
			<h1>Find sermons, confessions, and treatises.</h1>
			<p class="lede">
				Search by title, author name, or any word or phrase from the text. Use the author filter to narrow
				results to a single writer.
			</p>
		</div>
	</section>

	<section class="search-shell">
		<form class="search-form" id="library-search-form">
			<div class="search-controls">
				<input
					id="library-search-input"
					type="search"
					name="q"
					placeholder="Search sermons, confessions, treatises…"
					aria-label="Search historical Particular Baptist texts"
				/>
				<select id="author-filter" aria-label="Filter by author">
					<option value="">All authors</option>
					{
						authors.map((author) => (
							<option value={author.slug}>{author.name}</option>
						))
					}
				</select>
			</div>
			<button class="button button-primary" type="submit">Search</button>
		</form>
	</section>

	<section class="search-result-list" id="search-results">
		<article class="search-result-card search-prompt-card">
			<h2 class="result-title">Enter a search above</h2>
			<p>Try searching for a name, topic, or phrase — such as "covenant", "baptism", or "Benjamin Keach".</p>
		</article>
	</section>

	<script is:inline>
		const form = document.querySelector('#library-search-form');
		const input = document.querySelector('#library-search-input');
		const authorFilter = document.querySelector('#author-filter');
		const resultsContainer = document.querySelector('#search-results');

		const createCard = (result) => `
			<article class="search-result-card">
				<p class="result-kicker">${result.author}</p>
				<h2 class="result-title">${result.title}</h2>
				<p>${result.snippet}</p>
				<a class="text-link" href="/works/${result.slug}">Read this work →</a>
			</article>
		`;

		const renderResults = (results, query) => {
			if (!resultsContainer) return;
			if (!results.length) {
				resultsContainer.innerHTML = `
					<article class="search-result-card">
						<h2 class="result-title">No results found</h2>
						<p>No works matched "${query}". Try a different spelling or a broader term.</p>
					</article>
				`;
				return;
			}
			resultsContainer.innerHTML = results.map(createCard).join('');
		};

		const scoreResult = (entry, normalizedQuery) => {
			const haystack = (entry.title + ' ' + entry.author + ' ' + entry.searchText).toLowerCase();
			if (!normalizedQuery) return 1;
			if (entry.title.toLowerCase().includes(normalizedQuery)) return 5;
			if (entry.author.toLowerCase().includes(normalizedQuery)) return 4;
			if (haystack.includes(normalizedQuery)) return 3;
			return 0;
		};

		const performSearch = async () => {
			const normalizedQuery = (input?.value ?? '').trim().toLowerCase();
			const author = authorFilter?.value ?? '';
			if (!normalizedQuery && !author) {
				if (resultsContainer) {
					resultsContainer.innerHTML = `
						<article class="search-result-card search-prompt-card">
							<h2 class="result-title">Enter a search above</h2>
							<p>Try searching for a name, topic, or phrase — such as "covenant", "baptism", or "Benjamin Keach".</p>
						</article>
					`;
				}
				return;
			}
			const response = await fetch('/search-index.json');
			const entries = await response.json();
			const filtered = entries
				.filter((entry) => !author || entry.authorSlug === author)
				.map((entry) => ({ ...entry, score: scoreResult(entry, normalizedQuery) }))
				.filter((entry) => entry.score > 0 || !normalizedQuery)
				.sort((a, b) => b.score - a.score || a.title.localeCompare(b.title))
				.slice(0, 24);

			renderResults(filtered, normalizedQuery || author);

			const params = new URLSearchParams(window.location.search);
			if (normalizedQuery) params.set('q', normalizedQuery);
			else params.delete('q');
			if (author) params.set('author', author);
			else params.delete('author');
			const next = window.location.pathname + (params.toString() ? '?' + params.toString() : '');
			window.history.replaceState({}, '', next);
		};

		form?.addEventListener('submit', (event) => {
			event.preventDefault();
			void performSearch();
		});

		input?.addEventListener('input', () => {
			clearTimeout(window._searchDebounce);
			window._searchDebounce = setTimeout(() => void performSearch(), 300);
		});

		authorFilter?.addEventListener('change', () => void performSearch());

		const params = new URLSearchParams(window.location.search);
		const q = params.get('q');
		const author = params.get('author');
		if (q && input) input.value = q;
		if (author && authorFilter) authorFilter.value = author;
		if (q || author) void performSearch();
	</script>
</SiteShell>
