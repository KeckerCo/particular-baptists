---
import type { CatalogWork } from '../../data/catalog';
import { works } from '../../data/catalog';
import SiteShell from '../../layouts/SiteShell.astro';
export const prerender = true;

export function getStaticPaths() {
return works.map((work) => ({
params: { slug: work.slug },
props: { work },
}));
}

interface Props {
work: CatalogWork;
}

const { work } = Astro.props;
const description = `${work.title} by ${work.author}. Read the full historical text from the Particular Baptists Library.`;
const isAvailable = !work.isThinExtraction;
const wordCountFormatted = work.wordCount > 0 ? work.wordCount.toLocaleString('en-GB') : null;
---

<SiteShell title={work.title} description={description}>
<section class="page-intro">
<div>
<p class="eyebrow"><a class="text-link" href={`/authors/${work.authorSlug}`}>{work.author}</a></p>
<h1>{work.title}</h1>
{work.pageCount && <p class="lede">{work.pageCount} pages</p>}
</div>
</section>

<section class="reading-layout">
<aside class="reading-sidebar">
<div>
<p class="eyebrow">About this work</p>
<ul class="reading-meta-list">
<li><strong>Author</strong><a class="text-link" href={`/authors/${work.authorSlug}`}>{work.author}</a></li>
{work.pageCount && <li><strong>Pages</strong>{work.pageCount}</li>}
{wordCountFormatted && <li><strong>Words</strong><span>{wordCountFormatted}</span></li>}
<li>
<strong>Text</strong>
<span class:list={['quality-badge', work.qualityLabel]}>
{work.qualityLabel === 'text-rich' ? 'Fully searchable' : 'Historical scan'}
</span>
</li>
</ul>
</div>
<div>
<a class="button button-secondary" href={`/search?author=${work.authorSlug}`}>More by {work.author}</a>
</div>
</aside>

<article class="reading-content">
<div class="reading-body">
{isAvailable ? (
work.sampleText.map((paragraph) => <p>{paragraph}</p>)
) : (
<div class="scan-notice">
<div class="scan-notice-accent"></div>
<svg class="scan-notice-icon" xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
<path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/>
<path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/>
</svg>
<h2 class="scan-notice-title">Historical Facsimile</h2>
<p class="scan-notice-body">This work survives as a scanned facsimile. The text has not yet been digitised and is not available for full-text reading or search. If you have access to a clean transcription or wish to contribute, please contact IRBS.</p>
{work.pageCount && <p class="scan-notice-meta">Scan: {work.pageCount} pages</p>}
<a class="button button-secondary" href="/search">Search available works</a>
</div>
)}
</div>
</article>
</section>
</SiteShell>
