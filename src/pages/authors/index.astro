---
import { authors } from '../../data/catalog';
import SiteShell from '../../layouts/SiteShell.astro';
export const prerender = true;

const description = 'Browse historical Particular Baptist writers and theologians from the 17th and 18th centuries.';

// Group authors by first letter for the alpha index
const byLetter = new Map<string, typeof authors>();
for (const author of authors) {
	const letter = author.name.charAt(0).toUpperCase();
	const bucket = byLetter.get(letter) ?? [];
	bucket.push(author);
	byLetter.set(letter, bucket);
}
const letters = Array.from(byLetter.keys()).sort();
---

<SiteShell title="Authors" description={description}>
	<section class="page-intro">
		<div>
			<p class="eyebrow">Browse by author</p>
			<h1>The writers of the Particular Baptist tradition.</h1>
			<p class="lede">
				Explore sermons, confessions, treatises, and histories written by the men and women who shaped
				Particular Baptist theology in 17th and 18th-century Britain and America.
			</p>
		</div>
	</section>

	{
		letters.map((letter) => (
			<section id={`letter-${letter}`} class="author-letter-group">
				<h2 class="alpha-section-head">{letter}</h2>
				<div class="author-grid">
					{byLetter.get(letter)!.map((author) => (
						<article class="author-list-card">
							<div class="author-row">
								<h3>{author.name}</h3>
								<span class="author-count">{author.works.length} {author.works.length === 1 ? 'work' : 'works'}</span>
							</div>
							<p class="author-summary">{author.summary}</p>
							<a class="text-link" href={`/authors/${author.slug}`}>Browse works →</a>
						</article>
					))}
				</div>
			</section>
		))
	}
</SiteShell>
